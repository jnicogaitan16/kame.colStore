{
  "name": "kame-colstore-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "test:headed": "playwright test --headed",
    "test:sandbox": "RUN_WOMPI_SANDBOX_E2E=1 playwright test -c playwright.sandbox.config.ts",
    "test:sandbox:nequi": "RUN_WOMPI_SANDBOX_E2E=1 playwright test e2e/payments-nequi-sandbox.spec.ts -c playwright.sandbox.config.ts",
    "test:sandbox:nequi:headed": "RUN_WOMPI_SANDBOX_E2E=1 E2E_PLAYWRIGHT_SLOW_MO=350 playwright test e2e/payments-nequi-sandbox.spec.ts -c playwright.sandbox.config.ts --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.5.2"
  }
}
